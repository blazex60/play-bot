DISCORD_TOKEN=your_discord_token_here
CLIENT_ID=your_application_client_id_here
DISCORD_CLIENT_ID=your_application_client_id_here

# Discord OAuth application client secret.
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
# Register this exact Discord redirect URI in the Discord Developer Portal.
DISCORD_OAUTH_REDIRECT=https://music.example.com/auth/discord/callback

# Register https://music.example.com/auth/spotify/callback in the Spotify Developer Dashboard.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Register https://music.example.com/auth/youtube/callback in Google Cloud OAuth settings.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# 32-byte base64 key for AES-256-GCM token encryption. Keep a backup outside the repo.
MUSICBOT_TOKEN_ENC_KEY=base64_32_byte_key_here
# Long random value for signing the music-web session cookie.
WEB_SESSION_SECRET=change_me_to_a_long_random_secret

# Shared bearer token used only between music-web and the loopback bot API.
BOT_API_TOKEN=change_me_to_a_long_random_internal_token
BOT_API_PORT=3001
BOT_API_URL=http://127.0.0.1:3001

WEB_PORT=3000
PUBLIC_BASE_URL=https://music.example.com

# Discord role ID allowed to use extended web controls without VC presence.
ADMIN_ROLE_ID=your_admin_role_id_here
