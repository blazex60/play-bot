{
  "name": "music-bot",
  "version": "1.0.0",
  "description": "Discord music bot using discord.js v14 + @discordjs/voice",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/deploy.js --if-changed && node src/index.js",
    "deploy": "node src/deploy.js",
    "test": "npm run test:server",
    "test:server": "node scripts/run-node-tests.mjs --suite server",
    "test:web": "vitest run --config web/vitest.config.js --reporter=verbose",
    "test:browser": "node scripts/run-browser-tests.mjs",
    "test:e2e": "npm run test:browser",
    "test:container": "node scripts/run-node-tests.mjs --suite container",
    "typecheck": "tsc --noEmit -p web/tsconfig.json && node -e \"console.log('P0_TYPECHECK_OK')\"",
    "build:web": "node scripts/build-web.mjs",
    "db:inspect": "node src/db/inspect.js",
    "plan:validate": "node test/plan/validate-plan.mjs",
    "qa:task": "node scripts/qa-task.mjs",
    "check": "npm run test:server && npm run test:web && npm run typecheck && npm run build:web && npm run test:e2e"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^12.4.1",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.6.2",
    "libsodium-wrappers": "^0.7.15",
    "opusscript": "^0.0.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "allowScripts": {
    "@discordjs/opus@0.10.0": true,
    "better-sqlite3@12.11.1": true,
    "esbuild@0.25.12": true
  }
}
